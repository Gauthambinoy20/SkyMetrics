# SkyMetrics environment configuration — copy to .env and fill in.
# No real secrets are committed; .env is git-ignored.

# --- External data APIs (all optional; scrapers fall back to cached data) ---
# OpenSky Network (https://opensky-network.org) — flight tracking
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# Reddit API (https://www.reddit.com/prefs/apps) — r/britishairways sentiment
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=skymetrics/0.1

# --- LLM (OpenRouter free models) — enables /summary and /chat ---
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- Storage ---
SKYMETRICS_DB_URL=sqlite:///skymetrics.db
SKYMETRICS_MODEL_PATH=models/booking.joblib

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8000
